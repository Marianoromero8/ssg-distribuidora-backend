# Server
NODE_ENV=development
PORT=3000

# Database (use DATABASE_URL for Neon, or individual vars for local)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ssg_distribuidora
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Cloudinary (create account at cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
